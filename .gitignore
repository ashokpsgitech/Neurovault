# External Binaries and Distributions
gradle-bin/
*.zip
*.tar.gz
*.tgz
.gradle-dist/
jdk-21.0.2/

# Gradle & Flutter Build directories
.gradle/
**/out/
**/bin/
.gradletasknamecache

# Ignore all build output except the release APK
frontend/build/*
!frontend/build/app/
!frontend/build/app/outputs/
!frontend/build/app/outputs/flutter-apk/
!frontend/build/app/outputs/flutter-apk/app-release.apk

# Compiled class files
*.class

# IDE & Editor files
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.classpath
.project

# System & OS Files
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
*.swp

# Log Files
*.log
**/logs/

# Sensitive data, Local Databases & Binary Container Allocations
*.env
.env.local
application-local.yml
application-local.properties
*.container
*.mv.db
neurovault-db*
neurovault-storage/
**/neurovault-storage/**
